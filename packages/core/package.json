{
  "name": "@gorenku/studio-core",
  "version": "0.1.0",
  "description": "Renku Studio domain model, validation, workflows, queue and projection primitives",
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "catalog",
    "dist",
    "drizzle",
    "drizzle.project-migrate.config.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate:project": "drizzle-kit migrate --config drizzle.project-migrate.config.ts",
    "test": "vitest run",
    "test:typecheck": "tsc --project tsconfig.vitest.json --noEmit",
    "check:all": "pnpm type-check && pnpm lint && pnpm test:typecheck",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "keywords": [
    "ai",
    "movie",
    "renku-studio",
    "workflow",
    "queue"
  ],
  "author": "",
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@gorenku/studio-diagnostics": "workspace:*",
    "@gorenku/studio-engines": "workspace:*",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "yaml": "^2.8.4"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.16.11",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/ui": "^3.2.4",
    "eslint": "^8",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
