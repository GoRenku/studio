---
import { workflow } from '../data/site';
---

<section class="workflow" id="workflow">
  <div class="container">
    <p class="eyebrow" data-reveal>The workflow</p>
    <h2 data-reveal style="--reveal-delay: 0.06s">
      Script in. Previs out. Five moves.
    </h2>
    <ol class="steps">
      {
        workflow.map((item, i) => (
          <li data-reveal style={`--reveal-delay: ${0.1 + i * 0.07}s`}>
            <span class="step-num">{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .workflow {
    padding-block: clamp(5rem, 12vh, 8rem) clamp(2rem, 6vh, 4rem);
    text-align: center;
  }

  h2 {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    margin-top: 0.9rem;
  }

  .steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 1rem;
    padding: 0;
    margin-top: 3rem;
    text-align: left;
  }

  .steps li {
    position: relative;
    padding: 1.5rem 1.25rem 1.4rem;
    border: 1px solid rgba(244, 239, 230, 0.08);
    border-radius: var(--radius-md);
    background: linear-gradient(180deg, var(--ink-850), var(--ink-900));
    transition:
      transform 0.3s var(--ease-out),
      border-color 0.3s var(--ease-out);
  }

  .steps li:hover {
    transform: translateY(-4px);
    border-color: rgba(253, 160, 45, 0.4);
  }

  .step-num {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--amber-500);
  }

  .steps h3 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 650;
    margin-top: 0.7rem;
    letter-spacing: 0;
  }

  .steps p {
    margin-top: 0.45rem;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--paper-500);
  }
</style>
