{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./server-dist",
    "rootDir": "./server",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@gorenku/studio-core/client": ["../core/dist/client/index.d.ts"],
      "@gorenku/studio-core/server": ["../core/dist/server/index.d.ts"]
    }
  },
  "include": ["./server/**/*.ts"],
  "exclude": ["./server/**/*.test.ts"]
}
