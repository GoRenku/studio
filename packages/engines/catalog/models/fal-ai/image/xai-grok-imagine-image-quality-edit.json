{
  "input_schema": {
    "properties": {
      "num_images": {
        "minimum": 1,
        "default": 1,
        "description": "Number of images to generate.",
        "maximum": 4,
        "title": "Number of Images",
        "type": "integer"
      },
      "image_urls": {
        "examples": [
          [
            "https://v3b.fal.media/files/b/0a8b911d/Abk8vStrvmSPlzUqI_NN3_image_043.png"
          ]
        ],
        "items": {
          "type": "string",
          "format": "uri"
        },
        "title": "Image URLs",
        "description": "List of URLs of the images to edit. A maximum of 3 images are supported.",
        "type": "array"
      },
      "resolution": {
        "default": "1k",
        "enum": [
          "1k",
          "2k"
        ],
        "title": "Resolution",
        "description": "Resolution of the generated image. `1k` for standard resolution, `2k` for high resolution.",
        "type": "string"
      },
      "output_format": {
        "enum": [
          "jpeg",
          "png",
          "webp"
        ],
        "description": "The format of the generated image.",
        "title": "Output Format",
        "default": "jpeg",
        "type": "string"
      },
      "sync_mode": {
        "description": "If `True`, the media will be returned as a data URI and the output data won't be available in the request history.",
        "title": "Sync Mode",
        "default": false,
        "type": "boolean"
      },
      "aspect_ratio": {
        "enum": [
          "auto",
          "2:1",
          "20:9",
          "19.5:9",
          "16:9",
          "4:3",
          "3:2",
          "1:1",
          "2:3",
          "3:4",
          "9:16",
          "9:19.5",
          "9:20",
          "1:2"
        ],
        "description": "Aspect ratio of the edited image. When set to `auto` (the default), the output preserves the aspect ratio of the first input image.",
        "title": "Aspect Ratio",
        "default": "auto",
        "type": "string"
      },
      "prompt": {
        "examples": [
          "Make this scene more realistic but still keep the game vibes"
        ],
        "maxLength": 8000,
        "description": "Text description of the desired image.",
        "title": "Prompt",
        "type": "string"
      }
    },
    "required": [
      "prompt"
    ],
    "x-fal-order-properties": [
      "prompt",
      "num_images",
      "aspect_ratio",
      "resolution",
      "output_format",
      "sync_mode",
      "image_urls"
    ],
    "title": "XAIImageEditQualityInput",
    "type": "object"
  },
  "output_schema": {
    "properties": {
      "images": {
        "examples": [
          [
            {
              "url": "https://v3b.fal.media/files/b/0a8b911d/XMqiVoO2ECXUZEUYmPl2l.jpg"
            }
          ]
        ],
        "items": {
          "$ref": "#/ImageFile"
        },
        "description": "The URL of the edited image.",
        "title": "Images",
        "type": "array"
      },
      "revised_prompt": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "The enhanced prompt that was used to generate the image.",
        "title": "Revised Prompt"
      }
    },
    "required": [
      "images"
    ],
    "x-fal-order-properties": [
      "images",
      "revised_prompt"
    ],
    "title": "XAIImageEditOutput",
    "type": "object"
  },
  "ImageFile": {
    "properties": {
      "url": {
        "description": "The URL where the file can be downloaded from.",
        "title": "Url",
        "type": "string",
        "format": "uri"
      },
      "file_name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "The name of the file. It will be auto-generated if not provided.",
        "title": "File Name",
        "examples": [
          "z9RV14K95DvU.png"
        ]
      },
      "height": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "The height of the image",
        "title": "Height"
      },
      "content_type": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "The mime type of the file.",
        "title": "Content Type",
        "examples": [
          "image/png"
        ]
      },
      "file_size": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "The size of the file in bytes.",
        "title": "File Size",
        "examples": [
          4404019
        ]
      },
      "width": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "The width of the image",
        "title": "Width"
      }
    },
    "required": [
      "url"
    ],
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size",
      "width",
      "height"
    ],
    "title": "ImageFile",
    "type": "object"
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "num_images",
        "image_urls",
        "resolution",
        "output_format",
        "sync_mode",
        "aspect_ratio",
        "prompt"
      ],
      "fields": {
        "num_images": {
          "pointer": "/input_schema/properties/num_images",
          "component": "integer",
          "label": "Num Images"
        },
        "image_urls": {
          "pointer": "/input_schema/properties/image_urls",
          "component": "array-file-uri",
          "label": "Image Urls",
          "item": {
            "pointer": "/input_schema/properties/image_urls/items",
            "component": "file-uri",
            "label": "Item"
          }
        },
        "resolution": {
          "pointer": "/input_schema/properties/resolution",
          "component": "string-enum",
          "label": "Resolution"
        },
        "output_format": {
          "pointer": "/input_schema/properties/output_format",
          "component": "string-enum",
          "label": "Output Format"
        },
        "sync_mode": {
          "pointer": "/input_schema/properties/sync_mode",
          "component": "boolean",
          "label": "Sync Mode"
        },
        "aspect_ratio": {
          "pointer": "/input_schema/properties/aspect_ratio",
          "component": "string-enum",
          "label": "Aspect Ratio"
        },
        "prompt": {
          "pointer": "/input_schema/properties/prompt",
          "component": "string",
          "label": "Prompt"
        }
      }
    }
  }
}
